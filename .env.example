# =============================================================================
# Environment contract — TEMPLATE (names only, NEVER real values).
#
# Setup:  copy this file to `.env.local` and fill in real values.
#         `.env.local` is gitignored and must never be committed.
#
# Golden rule:
#   - NEXT_PUBLIC_*  -> embedded in the browser bundle. Public by design.
#   - everything else -> SERVER-ONLY. Must be read only from server modules
#     (Server Components, Server Actions, Route Handlers, `server-only` files).
#     A server-only secret must NEVER be given a NEXT_PUBLIC_ prefix, and must
#     NEVER be imported into a Client Component.
# =============================================================================

# -----------------------------------------------------------------------------
# PUBLIC (safe to expose to the browser)
# -----------------------------------------------------------------------------

# Supabase project URL. Public.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key. Public — Row Level Security is the real
# authorization boundary, not this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key. Public — rendered into the form widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# SERVER-ONLY (secrets — never sent to the browser)
# -----------------------------------------------------------------------------

# Supabase service-role key. BYPASSES RLS. Server-only. If this ever reaches the
# browser bundle, treat it as a credential leak and rotate it immediately.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile secret key. Used only for server-side token verification.
TURNSTILE_SECRET_KEY=

# =============================================================================
# CSP planning (DO NOT apply yet — only when the integration that needs it ships)
#
# These directives in next.config.ts `cspHeader` will be added later:
#   - When Supabase client lands (M3):
#       connect-src  += https://*.supabase.co  wss://*.supabase.co
#       img-src      += https://*.supabase.co        (Storage public images)
#   - When Turnstile lands on the contact form (M7-T2):
#       script-src   += https://challenges.cloudflare.com
#       frame-src     = https://challenges.cloudflare.com
#       connect-src  += https://challenges.cloudflare.com
#   - When EmailJS is removed (M7-T2): drop https://api.emailjs.com from connect-src.
# =============================================================================
